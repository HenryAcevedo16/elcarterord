<div class="breadcrumb">
  <a href="{{ routes.root_url }}">Inicio</a><span>›</span>
  <span class="current">Contacto</span>
</div>

<section class="wrap" style="max-width:820px; margin:0 auto;">

  <div class="row-header reveal" style="margin-bottom:36px;">
    <div>
      <p class="section-eyebrow">¿Tienes alguna duda?</p>
      <h1 class="section-title">Contáctanos</h1>
    </div>
  </div>

  <div style="display:grid; grid-template-columns:1fr 1.4fr; gap:36px; align-items:start;">

    <!-- INFO DE CONTACTO -->
    <div style="display:flex; flex-direction:column; gap:14px;">

      <a href="https://wa.me/18093269319"
         target="_blank" rel="noopener"
         class="trust-chip reveal"
         style="padding:20px; border-radius:16px; background:var(--sand); text-decoration:none; color:inherit; display:flex; gap:14px; align-items:center;">
        <span style="font-size:1.6rem;">💬</span>
        <div>
          <div style="font-weight:700; font-size:.9rem; margin-bottom:3px;">WhatsApp</div>
          <div style="color:var(--muted); font-size:.8rem; line-height:1.5;">Respuesta rápida<br>+1 (809) 326-9319</div>
        </div>
      </a>

      <a href="mailto:soporte@elcarterord.store"
         class="trust-chip reveal d1"
         style="padding:20px; border-radius:16px; background:var(--sand); text-decoration:none; color:inherit; display:flex; gap:14px; align-items:center;">
        <span style="font-size:1.6rem;">📧</span>
        <div>
          <div style="font-weight:700; font-size:.9rem; margin-bottom:3px;">Email</div>
          <div style="color:var(--muted); font-size:.8rem; line-height:1.5;">Respondemos en 24h<br>soporte@elcarterord.store</div>
        </div>
      </a>

      <div class="trust-chip reveal d2"
           style="padding:20px; border-radius:16px; background:var(--sand); display:flex; gap:14px; align-items:center;">
        <span style="font-size:1.6rem;">⏰</span>
        <div>
          <div style="font-weight:700; font-size:.9rem; margin-bottom:3px;">Horario de atención</div>
          <div style="color:var(--muted); font-size:.8rem; line-height:1.5;">{{ section.settings.hours }}</div>
        </div>
      </div>

    </div>

    <!-- FORMULARIO DE CONTACTO -->
    <div class="form-section reveal" style="padding:28px; border-radius:20px;">

      {% form 'contact' %}

        {% if form.posted_successfully? %}
          <div style="text-align:center; padding:32px 16px;">
            <div style="font-size:3rem; margin-bottom:12px;">✅</div>
            <h3 style="font-weight:700; color:#065f46; margin-bottom:8px;">¡Mensaje enviado!</h3>
            <p style="color:var(--muted); font-size:.9rem; line-height:1.6;">
              Gracias por escribirnos. Te responderemos lo antes posible por email o WhatsApp.
            </p>
          </div>

        {% else %}

          {% if form.errors %}
            <div style="background:#fef2f2; border:1px solid #fca5a5; border-radius:10px; padding:12px 16px; margin-bottom:20px; font-size:.85rem; color:#991b1b;">
              Por favor revisa los campos marcados en rojo.
            </div>
          {% endif %}

          <div class="form-grid">

            <div class="form-group">
              <label class="form-label" for="ContactName">Nombre</label>
              <input class="form-inp" type="text" id="ContactName"
                     name="contact[name]" value="{{ customer.name }}" placeholder="Tu nombre">
            </div>

            <div class="form-group">
              <label class="form-label" for="ContactPhone">Teléfono / WhatsApp</label>
              <input class="form-inp" type="tel" id="ContactPhone"
                     name="contact[phone]" placeholder="+1 (809) 000-0000">
            </div>

            <div class="form-group span2">
              <label class="form-label" for="ContactEmail">
                Correo electrónico *
                {% if form.errors contains 'email' %}
                  <span style="color:var(--red); font-size:.75rem;">— Campo requerido</span>
                {% endif %}
              </label>
              <input class="form-inp {% if form.errors contains 'email' %}error{% endif %}"
                     type="email" id="ContactEmail"
                     name="contact[email]" value="{{ customer.email }}"
                     placeholder="tu@correo.com" required>
            </div>

            <div class="form-group span2">
              <label class="form-label" for="ContactBody">
                Mensaje *
                {% if form.errors contains 'body' %}
                  <span style="color:var(--red); font-size:.75rem;">— Campo requerido</span>
                {% endif %}
              </label>
              <textarea class="form-textarea {% if form.errors contains 'body' %}error{% endif %}"
                        id="ContactBody" name="contact[body]"
                        placeholder="¿En qué podemos ayudarte?"
                        required style="min-height:130px;"></textarea>
            </div>

          </div>

          <button type="submit" class="btn-main" style="width:100%; margin-top:20px; font-size:.95rem;">
            Enviar mensaje →
          </button>

        {% endif %}

      {% endform %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "text",
      "id": "whatsapp",
      "label": "Número de WhatsApp",
      "default": "+1 (809) 326-9319"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Correo de contacto",
      "default": "soporte@elcarterord.store"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Horario de atención",
      "default": "Lun–Sáb: 9am–7pm\nDom: 10am–4pm"
    }
  ]
}
{% endschema %}
