<section class="wrap">
  <div class="row-header reveal">
    <div>
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>
    {% if section.settings.btn_link != blank %}
      <a href="{{ section.settings.btn_link }}" class="view-all">{{ section.settings.btn_text }} &rarr;</a>
    {% endif %}
  </div>

  <div class="cats-grid">
    {% for block in section.blocks %}
      {% assign collection = collections[block.settings.collection] %}
      <a href="{{ collection.url | default: block.settings.fallback_url | default: '#' }}"
         class="cat-card reveal"
         style="
           text-decoration:none;
           color:inherit;
           --cat-bg: {{ block.settings.color_bg }};
           --cat-accent: {{ block.settings.color_accent }};
           --cat-glow: {{ block.settings.color_glow }};
         "
         {{ block.shopify_attributes }}>
        <div class="cat-glow" style="background: radial-gradient(circle at 30% 30%, var(--cat-glow, rgba(34,194,68,0.25)), transparent 70%);"></div>

        <!-- Badge con contador de productos -->
        <span class="cat-chip" style="background: var(--cat-accent, #22c244); color:#fff;">
          {% if collection != blank %}
            {{ collection.all_products_count }}+
          {% else %}
            0+
          {% endif %}
        </span>

        <!-- Emoji grande -->
        <div class="cat-emoji-wrap" style="font-size: 3rem; margin: 20px 0 14px;">
          {{ block.settings.emoji | default: '✨' }}
        </div>

        <!-- Nombre: primero el título de la colección real, si no el del bloque -->
        <p class="cat-card-name">
          {{ collection.title | default: block.settings.name | default: 'Categoría' }}
        </p>
        <p class="cat-card-count">{{ block.settings.subtitle }}</p>

        <!-- Flecha -->
        <div class="cat-arrow" style="color: var(--cat-accent, #22c244);">→</div>
      </a>
    {% endfor %}
  </div>
</section>

<style>
  .cats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-top: 32px;
  }

  .cat-card {
    position: relative;
    background: var(--cat-bg, #f5f8f0);
    border-radius: 24px;
    padding: 28px 20px 22px;
    text-align: center;
    overflow: hidden;
    border: 1.5px solid rgba(0,0,0,0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    cursor: pointer;
  }

  .cat-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.10);
  }

  .cat-card .cat-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .cat-card > * { position: relative; z-index: 1; }

  .cat-chip {
    display: inline-block;
    padding: 3px 11px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .cat-emoji-wrap {
    line-height: 1;
  }

  .cat-card-name {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--dark, #1a2e1e);
    margin: 0 0 6px;
    letter-spacing: -0.02em;
  }

  .cat-card-count {
    font-size: 0.78rem;
    color: var(--muted, #6b8f72);
    margin: 0 0 12px;
    line-height: 1.4;
  }

  .cat-arrow {
    font-size: 1.1rem;
    font-weight: 700;
    transition: transform 0.2s;
  }

  .cat-card:hover .cat-arrow {
    transform: translateX(5px);
  }

  @media (max-width: 640px) {
    .cats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Categorías Destacadas",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño arriba",
