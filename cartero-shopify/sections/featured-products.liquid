<div class="products-wrap">
  <div class="row-header reveal">
    <div>
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>
    {% if section.settings.btn_link != blank %}
      <a href="{{ section.settings.btn_link }}" class="view-all">{{ section.settings.btn_text }} &rarr;</a>
    {% endif %}
  </div>

  <div class="prods-grid">
    {% assign collection = collections[section.settings.collection] %}
    {% for product in collection.products limit: section.settings.product_limit %}

      <div class="prod reveal">
        <a href="{{ product.url }}" class="prod-thumb" style="background: linear-gradient(135deg, #f5f0e8, #e8e0d0); text-decoration:none; display:flex;">
          <!-- Fallback de imagen usando emojis por ahora, o product.featured_image -->
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: 'medium' }}" alt="{{ product.title }}" style="width:100%; height:100%; object-fit:contain;">
          {% else %}
            <span>📦</span>
          {% endif %}
          
          {% if product.compare_at_price > product.price %}
            <span class="prod-label lb-hot">Oferta</span>
          {% endif %}
          <button class="prod-wish-btn"
                  data-wish-id="{{ product.id }}"
                  data-wish-title="{{ product.title | escape }}"
                  data-wish-img="{% if product.featured_image %}{{ product.featured_image | img_url: 'medium' }}{% endif %}"
                  data-wish-price="{{ product.price | money }}"
                  data-wish-url="{{ product.url }}"
                  onclick="toggleWish(this)"
                  aria-label="Guardar en favoritos">♡</button>
        </a>
        
        <div class="prod-info">
          <p class="prod-cat">{{ collection.title }}</p>
          <p class="prod-stars"><span class="stars-y">★★★★★</span></p>
          
          <a href="{{ product.url }}" style="text-decoration:none; color:inherit;">
             <p class="prod-name">{{ product.title }}</p>
          </a>
          
          <div class="prod-bottom">
            <div class="prod-price-block">
              {% if product.compare_at_price > product.price %}
                <span class="prod-price-old">{{ product.compare_at_price | money }}</span>
              {% endif %}
              <span class="prod-price-now">{{ product.price | money }}</span>
            </div>
            <form method="post" action="/cart/add" class="ajax-cart-form" style="margin:0;">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
              <input type="hidden" name="quantity" value="1" />
              <button type="submit" class="prod-cart-btn">+</button>
            </form>
          </div>
        </div>
      </div>

    {% else %}
      <!-- Fallback visual si no se ha seleccionado ninguna colección en Shopify aún -->
      {% for i in (1..4) %}
        <div class="prod reveal">
          <div class="prod-thumb" style="background:#f5f0e8;">
            <span>🛒</span>
          </div>
          <div class="prod-info">
            <p class="prod-cat">Categoría</p>
            <p class="prod-stars"><span class="stars-y">★★★★★</span> (0)</p>
            <p class="prod-name">Producto de Ejemplo {{ i }}</p>
            <div class="prod-bottom">
              <div class="prod-price-block">
                <span class="prod-price-now">$99.99</span>
              </div>
              <button class="prod-cart-btn">+</button>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Destacados"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Más vendidos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Display"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 4,
      "max": 12,
      "step": 4,
      "label": "Maximum products to show",
      "default": 8
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Ver todo"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "category": "Products"
    }
  ]
}
{% endschema %}
