{% comment %} CART PAGE — El Cartero {% endcomment %}

<div class="breadcrumb">
  <a href="{{ routes.root_url }}">Inicio</a><span>›</span>
  <span class="current">Tu carrito</span>
</div>

{% if cart.item_count > 0 %}

  <!-- ===== VISTA DEL CARRITO ===== -->
  <div style="max-width:720px; margin: 32px auto; padding: 0 20px;">

    <h1 class="section-title" style="margin-bottom:24px;">
      🛒 Tu carrito
      <span style="font-size:1rem; font-weight:500; color:var(--muted);">({{ cart.item_count }} artículo{% if cart.item_count > 1 %}s{% endif %})</span>
    </h1>

    <!-- ITEMS -->
    <div class="order-items" style="margin-bottom:24px;">
      {% for item in cart.items %}
        <div class="oi" style="align-items:center;">
          <div class="oi-img" style="background-image:url('{{ item.image | img_url: 'small' }}'); background-size:cover; background-color:#f5f0e8; background-position:center; flex-shrink:0;">
            <span class="oi-qty">{{ item.quantity }}</span>
          </div>
          <div class="oi-info" style="flex:1;">
            <a href="{{ item.url }}" style="text-decoration:none; color:inherit;">
              <div class="oi-name">{{ item.product.title }}</div>
            </a>
            {% unless item.product.has_only_default_variant %}
              <div class="oi-variant">{{ item.variant.title }}</div>
            {% endunless %}
            <div style="display:flex; gap:14px; align-items:center; margin-top:6px;">
              <button onclick="ajaxQty({{ forloop.index }}, {{ item.quantity | minus: 1 }})"
                 style="font-size:1.1rem; color:var(--muted); background:none; border:none; cursor:pointer; line-height:1; padding:0;">−</button>
              <span id="qty-{{ forloop.index }}" style="font-size:0.85rem; font-weight:700; min-width:16px; text-align:center;">{{ item.quantity }}</span>
              <button onclick="ajaxQty({{ forloop.index }}, {{ item.quantity | plus: 1 }})"
                 style="font-size:1.1rem; color:var(--muted); background:none; border:none; cursor:pointer; line-height:1; padding:0;">+</button>
              <button onclick="ajaxQty({{ forloop.index }}, 0)"
                 style="font-size:0.7rem; color:#e74c3c; background:none; border:none; cursor:pointer; text-decoration:underline; margin-left:8px;">Quitar</button>
            </div>
          </div>
          <span class="oi-price" style="flex-shrink:0; font-weight:700; margin-left:12px;">{{ item.line_price | money }}</span>
        </div>
      {% endfor %}
    </div>

    <!-- TOTALES -->
    <div class="sum-divider"></div>
    <div class="sum-row">
      <span class="sum-label">Subtotal</span>
      <span class="sum-val">{{ cart.total_price | money }}</span>
    </div>
    <div class="sum-row">
      <span class="sum-label">Envío</span>
      <span class="sum-val green">Gratis / A coordinar</span>
    </div>
    <div class="sum-row" style="align-items:flex-start;">
      <span class="sum-label">⏱ Tiempo de entrega</span>
      <span class="sum-val" style="text-align:right; font-weight:700;">2 – 3 días hábiles<br><span style="font-size:.7rem; font-weight:400; color:var(--muted);">Desde la confirmación del pedido</span></span>
    </div>
    <div class="sum-divider"></div>
    <div class="sum-total-row" style="margin-bottom:24px;">
      <span class="sum-total-label">Total estimado</span>
      <span class="sum-total-val">{{ cart.total_price | money }}</span>
    </div>

    <!-- CHIP ENTREGA -->
    <div class="cod-chip" style="margin-bottom:28px;">
      <span class="cod-icon">🚚</span>
      <div>
        <div class="cod-text">Entrega en 2 – 3 días hábiles</div>
        <div class="cod-sub">Confirmamos tu pedido por WhatsApp · Pago contra entrega</div>
      </div>
    </div>

    <!-- BOTONES -->
    <div style="display:flex; gap:12px; flex-wrap:wrap;">
      <a href="/collections/all" class="btn-sec"
         style="flex:1; min-width:160px; text-align:center; text-decoration:none; display:flex; align-items:center; justify-content:center;">
        ← Seguir comprando
      </a>
      <button onclick="abrirFormulario()" class="btn-submit"
              style="flex:2; min-width:200px; margin:0;">
        ✅ Confirmar pedido &mdash; {{ cart.total_price | money }}
      </button>
    </div>

  </div>

{% else %}

  <!-- CARRITO VACÍO -->
  <div style="text-align:center; padding:80px 20px; max-width:400px; margin:0 auto;">
    <div style="font-size:4rem; margin-bottom:16px;">🛒</div>
    <h2 style="font-size:1.4rem; font-weight:700; margin-bottom:12px;">Tu carrito está vacío</h2>
    <p style="color:var(--muted); margin-bottom:28px;">¡Agrega algunos productos para empezar!</p>
    <a href="/collections/all" class="btn-main" style="text-decoration:none;">Explorar tienda →</a>
  </div>

{% endif %}


<!-- ===================================================== -->
<!-- MODAL: FORMULARIO DE DATOS DE ENTREGA                 -->
<!-- ===================================================== -->
<div class="modal-overlay" id="formModal">
  <div class="modal" style="max-width:500px; width:92%; max-height:90vh; overflow-y:auto; padding:28px;">

    <!-- CABECERA -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:22px;">
      <h2 style="font-size:1.15rem; font-weight:700; margin:0;">📋 Datos de entrega</h2>
      <button onclick="cerrarFormulario()"
              style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:var(--muted); line-height:1; padding:4px 8px;">
        ×
      </button>
    </div>

    <!-- CAMPOS -->
    <div class="form-grid">

      <div class="form-group">
        <label class="form-label" for="fNombre">Nombre *</label>
        <input class="form-inp" id="fNombre" type="text" placeholder="María" autocomplete="given-name">
      </div>

      <div class="form-group">
        <label class="form-label" for="fApellido">Apellido *</label>
        <input class="form-inp" id="fApellido" type="text" placeholder="González" autocomplete="family-name">
      </div>

      <div class="form-group span2">
        <label class="form-label" for="fWhatsapp">WhatsApp / Teléfono *</label>
        <input class="form-inp" id="fWhatsapp" type="tel" placeholder="+1 (809) 000-0000" autocomplete="tel">
        <span style="font-size:.7rem; color:var(--muted); margin-top:4px; display:block;">
          Te contactamos aquí para coordinar entrega y pago
        </span>
      </div>

      <div class="form-group span2">
        <label class="form-label" for="fEmail">Correo electrónico *</label>
        <input class="form-inp" id="fEmail" type="email" placeholder="maria@correo.com" autocomplete="email">
      </div>

      <div class="form-group span2">
        <label class="form-label" for="fPais">País *</label>
        <select class="form-select" id="fPais" autocomplete="country">
          <option>República Dominicana</option>
          <option>México</option>
          <option>Colombia</option>
          <option>Venezuela</option>
          <option>Argentina</option>
          <option>España</option>
          <option>Estados Unidos</option>
        </select>
      </div>

      <div class="form-group span2">
        <label class="form-label" for="fDireccion">Dirección *</label>
        <input class="form-inp" id="fDireccion" type="text" placeholder="Calle Principal #123, Apto 4B" autocomplete="street-address">
      </div>

      <div class="form-group">
        <label class="form-label" for="fCiudad">Ciudad *</label>
        <input class="form-inp" id="fCiudad" type="text" placeholder="Santo Domingo" autocomplete="address-level2">
      </div>

      <div class="form-group">
        <label class="form-label" for="fProvincia">Provincia / Estado</label>
        <input class="form-inp" id="fProvincia" type="text" placeholder="Distrito Nacional" autocomplete="address-level1">
      </div>

      <div class="form-group span2">
        <label class="form-label" for="fNotas">Notas del pedido <span style="font-weight:400; color:var(--muted);">(opcional)</span></label>
        <textarea class="form-textarea" id="fNotas" placeholder="Ej: Dejar con el portero, llamar antes de llegar..."></textarea>
      </div>

    </div>

    <!-- TOTAL + BOTÓN ENVIAR -->
    <div style="margin-top:20px; padding-top:18px; border-top:1px solid rgba(0,0,0,.08);">
      <div class="sum-total-row" style="margin-bottom:16px;">
        <span class="sum-total-label">Total a pagar</span>
        <span class="sum-total-val">{{ cart.total_price | money }}</span>
      </div>
      <button class="btn-submit" id="submitBtn" onclick="enviarPedido()" style="width:100%; margin:0;">
        <span class="btn-label" id="btnLabel">✅ Completar pedido</span>
        <div class="spinner"></div>
      </button>
      <p class="submit-note" style="margin-top:10px;">
        Recibirás la confirmación por WhatsApp y correo.
      </p>
    </div>

  </div>
</div>


<!-- ===================================================== -->
<!-- MODAL: PEDIDO CONFIRMADO (ÉXITO)                      -->
<!-- ===================================================== -->
<div class="modal-overlay" id="successModal">
  <div class="modal" style="max-width:420px; width:92%; text-align:center;">
    <span class="modal-icon">🎉</span>
    <h2 class="modal-title">¡Pedido <span>confirmado!</span></h2>
    <p class="modal-sub">Tu orden fue registrada. Te contactaremos por WhatsApp en breve.</p>
    <div class="modal-order-box">
      <div class="mob-item">
        <div class="mob-label">Número de pedido</div>
        <div class="mob-val" id="modalOrderNum"></div>
      </div>
    </div>
    <div class="whatsapp-notice">
      <span class="wa-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28">
          <circle cx="12" cy="12" r="12" fill="#25D366"/>
          <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2-.2.2-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4a8.6 8.6 0 0 1-1.6-2c-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.1-.3.2-.5a.5.5 0 0 0 0-.5L9.3 8c-.2-.6-.5-.5-.7-.5h-.6a1.2 1.2 0 0 0-.8.3A3.4 3.4 0 0 0 6.1 10a6 6 0 0 0 1.2 3.1 13.7 13.7 0 0 0 5.2 4.6 6.3 6.3 0 0 0 2.3.7 3 3 0 0 0 2-.7 2.8 2.8 0 0 0 .8-1.7c0-.3-.2-.4-.4-.5z" fill="#fff"/>
        </svg>
      </span>
      <div class="wa-text">
        <strong>¡Te contactaremos por WhatsApp!</strong>
        <p>Mantén tu celular a mano.</p>
      </div>
    </div>
    <div class="modal-actions">
      <a href="/" class="modal-btn-main"
         style="display:flex; justify-content:center; align-items:center; text-decoration:none;">
        🏠 Volver al inicio
      </a>
    </div>
  </div>
</div>


<!-- ===================================================== -->
<!-- SCRIPT DEL CARRITO                                    -->
<!-- ===================================================== -->
<script>
const SHEETS_URL = 'https://script.google.com/macros/s/AKfycbwZziCU5K9DQEMx4yPn1R0cb3WZq0UcnPmuD7f5nS_TlFmWNe5zoZuqwHQt5dLSF8MO/exec';

// ── Datos de Shopify inyectados en build-time ──
let shopifyTotal = "{{ cart.total_price | money }}";
let productosStr = "";
{% for item in cart.items %}
  productosStr += "{{ item.product.title | escape }} x{{ item.quantity }}, ";
{% endfor %}
productosStr = productosStr.replace(/,\s*$/, '');

// ── AJAX: cambiar cantidad sin recargar página ──
function ajaxQty(line, qty) {
  fetch('/cart/change.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ line, quantity: qty })
  })
  .then(r => r.json())
  .then(cart => {
    // Si el carrito quedó vacío o se quitó un item, recargar
    if (cart.item_count === 0 || qty === 0) { location.reload(); return; }

    // Actualizar cantidad visible
    const qtyEl = document.getElementById('qty-' + line);
    if (qtyEl) qtyEl.textContent = qty;

    // Actualizar badge del header
    const badge = document.getElementById('cartBadge');
    if (badge) badge.textContent = cart.item_count;

    // Actualizar precios de línea y total en pantalla
    cart.items.forEach((item, i) => {
      const priceEls = document.querySelectorAll('.oi-price');
      if (priceEls[i]) {
        priceEls[i].textContent = formatMoney(item.line_price);
      }
    });

    // Actualizar totales
    const totalEls = document.querySelectorAll('.sum-val, .sum-total-val');
    totalEls.forEach(el => {
      if (el.classList.contains('green')) return; // No tocar el de "Gratis"
      el.textContent = formatMoney(cart.total_price);
    });

    // Actualizar el botón de confirmar pedido
    const confirmBtn = document.querySelector('.btn-submit');
    if (confirmBtn) {
      confirmBtn.innerHTML = '\u2705 Confirmar pedido — ' + formatMoney(cart.total_price);
    }

    // Actualizar la variable global para el formulario
    shopifyTotal = formatMoney(cart.total_price);
  })
  .catch(() => location.reload());
}

// Convierte centavos a formato de dinero: 4500 → "$45.00"
function formatMoney(cents) {
  return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

// ── Abrir / cerrar modal ───────────────────────
function abrirFormulario() {
  document.getElementById('formModal').classList.add('show');
  document.body.style.overflow = 'hidden';
}
function cerrarFormulario() {
  document.getElementById('formModal').classList.remove('show');
  document.body.style.overflow = '';
}

// Cerrar al hacer clic en el fondo oscuro
document.getElementById('formModal').addEventListener('click', function(e) {
  if (e.target === this) cerrarFormulario();
});

// ── Validación ─────────────────────────────────
function marcarError(id, hasError) {
  const el = document.getElementById(id);
  el.classList.toggle('error', hasError);
  el.classList.toggle('valid', !hasError && el.value.trim() !== '');
}

function validarForm() {
  const requeridos = ['fNombre', 'fApellido', 'fWhatsapp', 'fDireccion', 'fCiudad'];
  let ok = true;
  requeridos.forEach(id => {
    const empty = !document.getElementById(id).value.trim();
    marcarError(id, empty);
    if (empty) ok = false;
  });
  const emailVal = document.getElementById('fEmail').value;
  const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal);
  marcarError('fEmail', !emailOk);
  if (!emailOk) ok = false;
  return ok;
}

// ── Generador de número de pedido ─────────────
function generarNum() {
  return '#EC-' + new Date().getFullYear() + '-' + Math.floor(1000 + Math.random() * 9000);
}

// ── Envío del pedido ───────────────────────────
async function enviarPedido() {
  if (!validarForm()) {
    // Scroll al primer campo con error
    const errEl = document.querySelector('#formModal .error');
    if (errEl) errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  const btn   = document.getElementById('submitBtn');
  const label = document.getElementById('btnLabel');
  btn.classList.add('loading');
  btn.disabled = true;
  label.textContent = 'Enviando...';

  const orderNum = generarNum();
  const payload  = {
    orderNum,
    fecha:      new Date().toLocaleString('es-DO'),
    nombre:     document.getElementById('fNombre').value.trim(),
    apellido:   document.getElementById('fApellido').value.trim(),
    email:      document.getElementById('fEmail').value.trim(),
    telefono:   document.getElementById('fWhatsapp').value.trim(),
    pais:       document.getElementById('fPais').value,
    direccion:  document.getElementById('fDireccion').value.trim(),
    ciudad:     document.getElementById('fCiudad').value.trim(),
    provincia:  document.getElementById('fProvincia').value.trim(),
    notas:      document.getElementById('fNotas').value.trim(),
    productos:  productosStr,
    total:      shopifyTotal,
    estado:     'Pendiente'
  };

  try {
    if (SHEETS_URL && SHEETS_URL !== 'TU_URL_DE_APPS_SCRIPT_AQUI') {
      await fetch(SHEETS_URL, {
        method:  'POST',
        mode:    'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ ...payload, _token: 'EC2026RD' })
      });
    }
    mostrarExito(orderNum);
  } catch (err) {
    console.error('Error al enviar pedido:', err);
    mostrarExito(orderNum); // Mostrar éxito igual — la petición no-cors siempre llega
  }
}

function mostrarExito(orderNum) {
  document.getElementById('modalOrderNum').textContent = orderNum;
  document.getElementById('formModal').classList.remove('show');
  document.getElementById('successModal').classList.add('show');
}
</script>

{% schema %}
{
  "name": "Cart — Formulario de Pedido",
  "settings": []
}
{% endschema %}
