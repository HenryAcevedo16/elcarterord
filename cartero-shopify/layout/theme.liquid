<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#1a2e1e">
  
  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <!-- Open Graph / Social sharing -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:description" content="{{ page_description | default: shop.description | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if product.featured_image -%}
    <meta property="og:image" content="{{ product.featured_image | img_url: '1200x630' }}">
  {%- elsif collection.image -%}
    <meta property="og:image" content="{{ collection.image | img_url: '1200x630' }}">
  {%- elsif settings.share_image -%}
    <meta property="og:image" content="{{ settings.share_image | img_url: '1200x630' }}">
  {%- endif -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }}">
  <meta name="twitter:description" content="{{ page_description | default: shop.description | escape }}">

  <!-- Fuentes de Google -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <!-- Estilos Globales -->
  {{ 'cartero-base.css' | asset_url | stylesheet_tag }}

  <!-- Estilos del panel de favoritos -->
  <style>
    /* Wishlist panel */
    #wishOverlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,.45);
      z-index: 9998;
    }
    #wishOverlay.open { display: block; }
    #wishPanel {
      position: fixed; top: 0; right: -360px;
      width: 340px; max-width: 100vw;
      height: 100vh;
      background: #fff;
      z-index: 9999;
      display: flex; flex-direction: column;
      padding: 24px 20px;
      transition: right 0.3s ease;
      box-shadow: -4px 0 24px rgba(0,0,0,.12);
      overflow-y: auto;
    }
    #wishPanel.open { right: 0; }
    /* Botón corazón activo — usa --red que en este tema es el verde de marca */
    .prod-wish-btn.wished {
      background: var(--red, #22c244) !important;
      color: #fff !important;
    }

    /* Modal de bienvenida */
    #welcomeOverlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,.55);
      z-index: 10000;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(4px);
    }
    #welcomeOverlay.show {
      display: flex;
    }
    #welcomeBox {
      background: #fff;
      border-radius: 24px;
      padding: 36px 32px 28px;
      max-width: 420px;
      width: 92%;
      text-align: center;
      position: relative;
      animation: wlBounceIn 0.45s cubic-bezier(0.34,1.4,0.64,1);
    }
    @keyframes wlBounceIn {
      from { opacity:0; transform: scale(0.88) translateY(16px); }
      to   { opacity:1; transform: scale(1) translateY(0); }
    }
    .wl-icon-ring {
      width: 72px; height: 72px; border-radius: 50%;
      background: var(--cream, #e8f5eb);
      display: flex; align-items: center; justify-content: center;
      font-size: 2.2rem; margin: 0 auto 20px;
    }
    #welcomeBox h2 {
      font-size: 1.6rem; font-weight: 800;
      letter-spacing: -0.03em; line-height: 1.2;
      margin-bottom: 12px; color: var(--dark, #1a2e1e);
    }
    #welcomeBox p {
      font-size: 0.85rem; color: var(--muted, #6b8f72);
      line-height: 1.7; margin-bottom: 24px;
    }
    #welcomeBox strong { color: var(--dark, #1a2e1e); }
    .wl-btn-ok {
      background: var(--red, #22c244); color: #fff;
      border: none; border-radius: 14px;
      padding: 14px 32px; width: 100%;
      font-family: 'Poppins', sans-serif;
      font-size: 0.9rem; font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .wl-btn-ok:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(34,194,68,0.35);
    }
    .wl-chips {
      display: flex; gap: 8px; justify-content: center;
      flex-wrap: wrap; margin-bottom: 20px;
    }
    .wl-chip {
      display: inline-flex; align-items: center; gap: 5px;
      background: var(--cream, #e8f5eb);
      border-radius: 50px; padding: 5px 12px;
      font-size: 0.72rem; font-weight: 600;
      color: var(--dark, #1a2e1e);
    }
  </style>
</head>

<body>
  
  <!-- El Header dinámico -->
  {% section 'header' %}

  <!-- Aquí se inyecta el contenido de cada página (index, product, collection, etc) -->
  <main id="MainContent" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- El Footer dinámico -->
  {% section 'footer' %}

  <!-- Toast para notificaciones -->
  <div class="toast" id="toast">🛒 ¡Agregado al carrito!</div>

  <!-- PANEL LATERAL DE FAVORITOS -->
  <div id="wishOverlay"></div>
  <div id="wishPanel">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-shrink:0;">
      <h2 style="font-size:1.05rem; font-weight:700; margin:0;">♡ Mis favoritos</h2>
      <button onclick="wlTogglePanel()"
              style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:#999; line-height:1; padding:2px 8px;">
        ×
      </button>
    </div>
    <div id="wishPanelContent" style="flex:1;"></div>
  </div>

  <!-- Wishlist JS -->
  {{ 'wishlist.js' | asset_url | script_tag }}

  <!-- MODAL DE BIENVENIDA (una vez por sesión) -->
  <div id="welcomeOverlay" role="dialog" aria-modal="true" aria-labelledby="welcomeTitle">
    <div id="welcomeBox">
      <div class="wl-icon-ring">
        <svg xmlns="http://www.w3.org/2000/svg" width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="#22c244" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
          <line x1="12" y1="22.08" x2="12" y2="12"/>
          <polyline points="7.5 4.21 12 6.81 16.5 4.21"/>
        </svg>
      </div>
      <h2 id="welcomeTitle">Compra sin registrarte</h2>
      <p>
        <strong>Con nosotros</strong> puedes hacer tu pedido sin crear ninguna cuenta.
        Solo completa el formulario con tus datos y
        <strong>te contactaremos por WhatsApp</strong> para confirmar y coordinar la entrega.
      </p>
      <div class="wl-chips">
        <span class="wl-chip">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" style="flex-shrink:0;vertical-align:middle">
            <circle cx="12" cy="12" r="12" fill="#22c244" />
            <path d="M10.2 16.4l-3.5-3.5 1.4-1.4 2.1 2.1 6.3-6.4 1.4 1.4-7.7 7.8" fill="#ffffff"/>
          </svg>
          Sin registro
        </span>
        <span class="wl-chip">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" style="flex-shrink:0;vertical-align:middle">
            <circle cx="12" cy="12" r="12" fill="#25D366"/>
            <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.2-.2.2-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4a8.6 8.6 0 0 1-1.6-2c-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.1-.3.2-.5a.5.5 0 0 0 0-.5L9.3 8c-.2-.6-.5-.5-.7-.5h-.6a1.2 1.2 0 0 0-.8.3A3.4 3.4 0 0 0 6.1 10a6 6 0 0 0 1.2 3.1 13.7 13.7 0 0 0 5.2 4.6 6.3 6.3 0 0 0 2.3.7 3 3 0 0 0 2-.7 2.8 2.8 0 0 0 .8-1.7c0-.3-.2-.4-.4-.5z" fill="#fff"/>
          </svg>
          Confirmación por WhatsApp
        </span>
        <span class="wl-chip">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" style="flex-shrink:0;vertical-align:middle">
            <path d="M19 8h-3V5a1 1 0 00-1-1H3a1 1 0 00-1 1v12a1 1 0 001 1h1.1a3 3 0 005.8 0h4.2a3 3 0 005.8 0H21a1 1 0 001-1v-6l-3-3zM6 18a1 1 0 110-2 1 1 0 010 2zm11 0a1 1 0 110-2 1 1 0 010 2zm1-5h-2V9h1.5l1.5 1.5V13z" fill="#f5c518"/>
            <path d="M4 14v-2h12v2H4z" fill="#1a2e1e" opacity="0.1"/>
          </svg>
          Entrega en 2–3 días
        </span>
      </div>
      <button class="wl-btn-ok" onclick="cerrarBienvenida()">¡Entendido, empezar a comprar! →</button>
    </div>
  </div>

  <script>
    // Mostrar solo un máximo de 2 veces por usuario
    (function() {
      let count = parseInt(localStorage.getItem('elcartero_welcome_count') || '0', 10);
      if (count < 2) {
        document.getElementById('welcomeOverlay').classList.add('show');
        document.body.style.overflow = 'hidden';
      }
    })();
    function cerrarBienvenida() {
      let count = parseInt(localStorage.getItem('elcartero_welcome_count') || '0', 10);
      localStorage.setItem('elcartero_welcome_count', count + 1);
      document.getElementById('welcomeOverlay').classList.remove('show');
      document.body.style.overflow = '';
    }
    // Cerrar al hacer clic en el fondo
    document.getElementById('welcomeOverlay').addEventListener('click', function(e) {
      if (e.target === this) cerrarBienvenida();
    });
  </script>

  <!-- Intersection Observer básico para animaciones .reveal -->
  <script>
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.08 });
    document.addEventListener("DOMContentLoaded", function() {
      document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
    });
  </script>

  <!-- Script para Carrito AJAX -->
  <script>
    document.addEventListener("submit", function(e) {
      if (e.target.matches(".ajax-cart-form")) {
        e.preventDefault();
        const form = e.target;

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          body: new FormData(form)
        })
        .then(response => response.json())
        .then(() => {
          // Actualizar badge del carrito
          fetch('/cart.js').then(r => r.json()).then(cart => {
            let badge = document.getElementById('cartBadge');
            if (!badge) {
              const cartBtn = document.querySelector('a[href="/cart"]');
              if (cartBtn) {
                cartBtn.insertAdjacentHTML('beforeend', '<span class="badge" id="cartBadge">' + cart.item_count + '</span>');
              }
            } else {
              badge.innerText = cart.item_count;
            }
          });
          // Mostrar Toast de éxito
          const toast = document.getElementById('toast');
          if (toast) {
            toast.textContent = '🛒 ¡Agregado al carrito!';
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
          }
        })
        .catch(err => {
          console.error("Error adding to cart:", err);
          alert("Ocurrió un error al agregar el producto.");
        });
      }
    });
  </script>

</body>
</html>
